SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Почта: заявки с форм уходят на LEADS_NOTIFICATION_EMAIL (по умолчанию g.vlasov@axelot.ru).
# Для реальной отправки задайте SMTP (иначе в dev письма идут в консоль).
# LEADS_NOTIFICATION_EMAIL=g.vlasov@axelot.ru
# DEFAULT_FROM_EMAIL=noreply@axelot.ru
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true

# --- Пример: Microsoft 365 (Exchange Online) ---
# В центре администрирования Exchange: для ящика, с которого шлёте почту, должна быть включена
# «Аутентифицированная SMTP» (Authenticated SMTP). При включённой MFA — пароль приложения.
# https://learn.microsoft.com/exchange/clients-and-mobile-in-exchange-online/authenticated-client-smtp-submission
# LEADS_NOTIFICATION_EMAIL=g.vlasov@axelot.ru
# DEFAULT_FROM_EMAIL=noreply@ваш-домен.ru
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=полный_логин_ящика@ваш-домен.ru
# EMAIL_HOST_PASSWORD=пароль_или_пароль_приложения
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false

# --- Порты «наружу» (из интернета на ваш сервер / роутер с NAT) ---
# Что пробрасывать на машину с сайтом (Nginx), если сайт доступен из интернета:
#   80/tcp   — HTTP (сайт, редирект на HTTPS, проверка Let's Encrypt)
#   443/tcp  — HTTPS (основной доступ для посетителей)
#   22/tcp   — SSH (только администраторам; лучше VPN + закрыть 22 с интернета или ограничить по IP)
# НЕ публикуйте наружу: порт приложения за Nginx (например 8000), PostgreSQL (5432) и т.п.
#
# Почта из форм: Django сам подключается К почтовому серверу (исходящее соединение).
# Обычно с сервера достаточно исходящего доступа на 587/tcp или 465/tcp — отдельный «входящий»
# порт на вашем сайте для SMTP не открывается.
#
# «Провайдер» в смысле почты — это сервис/компания, которая держит вашу почту и даёт адрес SMTP
# (например корпоративный Exchange, Microsoft 365, Яндекс 360, Mail.ru для бизнеса и т.д.).
# В EMAIL_HOST указывают хост этого сервера (например smtp.office365.com), а не «название провайдера».
